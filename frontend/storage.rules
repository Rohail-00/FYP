rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Repository files ────────────────────────────────────────────────────
    // Path: repos/{uid}/{repoId}/{fileId}/{filename}
    // Only the authenticated owner (uid) can read or write their files.
    match /repos/{uid}/{repoId}/{fileId}/{filename} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Deny everything else ─────────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }

  }
}
