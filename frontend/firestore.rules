rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users collection ────────────────────────────────────────────────────
    match /users/{userId} {
      // Owner can create their own doc (during signup)
      allow create: if request.auth != null && request.auth.uid == userId;
      // Only the owner can read or update their own doc
      allow read, update: if request.auth != null && request.auth.uid == userId;
      // No one can delete user docs from client
      allow delete: if false;

      // ── Repositories sub-collection ─────────────────────────────────────
      match /repositories/{repoId} {
        // Only the owner can read/write their repositories
        allow read, create, update, delete:
          if request.auth != null && request.auth.uid == userId;

        // ── Files sub-collection ───────────────────────────────────────────
        match /files/{fileId} {
          // Only the owner can read/write file metadata
          allow read, create, update, delete:
            if request.auth != null && request.auth.uid == userId;
        }
      }
    }

  }
}
